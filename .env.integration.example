# Copy to .env.integration.local and adjust values for your local services.
PAI_TEST_DATABASE_ADDR=127.0.0.1:3306
PAI_TEST_DATABASE_USERNAME=root
PAI_TEST_DATABASE_PASSWORD=root
PAI_TEST_DATABASE_DBNAME=platform_mihomo_test
PAI_TEST_DATABASE_CONFIG=charset=utf8mb4&parseTime=True&loc=UTC&multiStatements=true

# Optional for now. Leave unset if a test does not require Redis.
# PAI_TEST_REDIS_ADDR=127.0.0.1:6379
# PAI_TEST_REDIS_PASSWORD=
# PAI_TEST_REDIS_DB=0
# PAI_TEST_REDIS_PREFIX=itest
